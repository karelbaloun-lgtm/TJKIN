# Netlify HTTP hlavičky — cache strategie

# Obrázky: cachovat 1 rok (mění se zřídka)
/images/*
  Cache-Control: public, max-age=31536000, immutable

# CSS a JS: cachovat 1 den
/*.css
  Cache-Control: public, max-age=86400

/*.js
  Cache-Control: public, max-age=86400

# HTML stránky: vždy čerstvé
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Manifest a sitemap: cachovat 1 den
/manifest.json
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=86400
